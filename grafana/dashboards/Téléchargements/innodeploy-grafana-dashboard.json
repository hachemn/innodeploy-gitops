{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "title": "innodeploy — Platform Overview",
  "uid": "innodeploy-platform",
  "tags": ["innodeploy", "kubernetes", "argocd", "rollout"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "schemaVersion": 38,
  "panels": [

    { "id": 1, "type": "row", "title": "Platform Health", "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 } },

    {
      "id": 2, "title": "App Status", "type": "stat",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{
        "expr": "up{job=\"innodeploy\"}",
        "legendFormat": "App Status"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "mappings": [
          { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
        ]
      },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 1 }] } } }
    },

    {
      "id": 3, "title": "Active Pods", "type": "stat",
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{
        "expr": "kube_deployment_status_replicas_available{deployment=\"innodeploy-app\"}",
        "legendFormat": "Ready Pods"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "yellow", "value": 1 }, { "color": "green", "value": 2 }] } } }
    },

    {
      "id": 4, "title": "Rollout Status", "type": "stat",
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{
        "expr": "rollout_info{rollout=\"innodeploy-app\"}",
        "legendFormat": "Rollout Phase"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "textMode": "value_and_name",
        "mappings": [{ "type": "value", "options": { "1": { "text": "Healthy", "color": "green" }, "0": { "text": "Degraded", "color": "red" } } }]
      },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 1 }] } } }
    },

    {
      "id": 5, "title": "Pod Restarts (1h)", "type": "stat",
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{
        "expr": "increase(kube_pod_container_status_restarts_total{namespace=\"default\", pod=~\"innodeploy.*\"}[1h])",
        "legendFormat": "Restarts"
      }],
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 3 }] } } }
    },

    { "id": 10, "type": "row", "title": "Resource Monitoring", "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 } },

    {
      "id": 11, "title": "CPU Usage — App Pods", "type": "timeseries",
      "gridPos": { "x": 0, "y": 6, "w": 6, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{
        "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"default\", pod=~\"innodeploy.*\", container!=\"\"}[2m])) by (pod)",
        "legendFormat": "{{pod}}"
      }],
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "percentunit", "custom": { "lineWidth": 1.5, "fillOpacity": 10 }, "color": { "mode": "palette-classic" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.9 }] } } }
    },

    {
      "id": 12, "title": "Memory Usage — App Pods", "type": "timeseries",
      "gridPos": { "x": 6, "y": 6, "w": 6, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{
        "expr": "sum(container_memory_working_set_bytes{namespace=\"default\", pod=~\"innodeploy.*\", container!=\"\"}) by (pod)",
        "legendFormat": "{{pod}}"
      }],
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "lineWidth": 1.5, "fillOpacity": 10 }, "color": { "mode": "palette-classic" } } }
    },

    {
      "id": 13, "title": "Node CPU — Minikube", "type": "gauge",
      "gridPos": { "x": 12, "y": 6, "w": 6, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{
        "expr": "1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[2m]))",
        "legendFormat": "Node CPU"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 0.6 }, { "color": "red", "value": 0.85 }] } } }
    },

    {
      "id": 14, "title": "Node Memory — Minikube", "type": "gauge",
      "gridPos": { "x": 18, "y": 6, "w": 6, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{
        "expr": "1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)",
        "legendFormat": "Node Memory"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.9 }] } } }
    },

    { "id": 20, "type": "row", "title": "Rollout & Deployment", "gridPos": { "x": 0, "y": 13, "w": 24, "h": 1 } },

    {
      "id": 21, "title": "Stable vs Canary Replicas", "type": "timeseries",
      "gridPos": { "x": 0, "y": 14, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "rollout_info{rollout=\"innodeploy-app\", type=\"stable\"}", "legendFormat": "Stable" },
        { "expr": "rollout_info{rollout=\"innodeploy-app\", type=\"canary\"}", "legendFormat": "Canary" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 15 } } }
    },

    {
      "id": 22, "title": "Deployment Frequency (per day)", "type": "timeseries",
      "gridPos": { "x": 8, "y": 14, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{
        "expr": "increase(argocd_app_sync_total{name=\"innodeploy-app\", phase=\"Succeeded\"}[24h])",
        "legendFormat": "Successful deploys"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 1.5, "drawStyle": "bars", "fillOpacity": 60 } } }
    },

    {
      "id": 23, "title": "Container Image Version", "type": "table",
      "gridPos": { "x": 16, "y": 14, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{
        "expr": "kube_pod_container_info{namespace=\"default\", pod=~\"innodeploy.*\"}",
        "legendFormat": "",
        "instant": true
      }],
      "options": { "showHeader": true },
      "fieldConfig": { "overrides": [ { "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "custom.hidden", "value": true }] } ] }
    },

    { "id": 30, "type": "row", "title": "GitOps & Alerts", "gridPos": { "x": 0, "y": 21, "w": 24, "h": 1 } },

    {
      "id": 31, "title": "ArgoCD App Sync Status", "type": "stat",
      "gridPos": { "x": 0, "y": 22, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "argocd_app_info{sync_status=\"Synced\"}", "legendFormat": "{{name}} — Synced" },
        { "expr": "argocd_app_info{sync_status=\"OutOfSync\"}", "legendFormat": "{{name}} — OutOfSync" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "textMode": "value_and_name",
        "mappings": [{ "type": "value", "options": { "1": { "text": "Synced", "color": "green" } } }]
      },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 1 }] } } }
    },

    {
      "id": 32, "title": "Active Alerts (Alertmanager)", "type": "alertlist",
      "gridPos": { "x": 8, "y": 22, "w": 8, "h": 6 },
      "options": {
        "alertName": "", "dashboardAlerts": false, "groupMode": "default",
        "maxItems": 10, "sortOrder": 1, "stateFilter": { "firing": true, "pending": true, "noData": false, "error": false, "inactive": false }
      }
    },

    {
      "id": 33, "title": "HTTP Request Rate", "type": "timeseries",
      "gridPos": { "x": 16, "y": 22, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(rate(http_requests_total{namespace=\"default\", job=~\"innodeploy.*\"}[2m])) by (status)", "legendFormat": "HTTP {{status}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 1.5, "fillOpacity": 10 } } }
    },

    {
      "id": 34, "title": "HTTP Error Rate (5xx)", "type": "timeseries",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{
        "expr": "sum(rate(http_requests_total{namespace=\"default\", job=~\"innodeploy.*\", status=~\"5..\"}[2m])) / sum(rate(http_requests_total{namespace=\"default\", job=~\"innodeploy.*\"}[2m]))",
        "legendFormat": "5xx error rate"
      }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "custom": { "lineWidth": 1.5, "fillOpacity": 20 }, "color": { "mode": "fixed", "fixedColor": "red" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 }] } } }
    },

    {
      "id": 35, "title": "Prometheus Rule Alerts Firing", "type": "timeseries",
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{
        "expr": "ALERTS{alertstate=\"firing\"}",
        "legendFormat": "{{alertname}}"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 1.5, "drawStyle": "bars", "fillOpacity": 60 }, "color": { "mode": "fixed", "fixedColor": "orange" } } }
    }

  ],

  "templating": {
    "list": [
      { "name": "namespace", "type": "query", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "definition": "label_values(kube_pod_info, namespace)", "label": "Namespace", "multi": false, "includeAll": false, "current": { "text": "default", "value": "default" } },
      { "name": "pod", "type": "query", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "definition": "label_values(kube_pod_info{namespace=\"$namespace\"}, pod)", "label": "Pod", "multi": true, "includeAll": true }
    ]
  }
}
