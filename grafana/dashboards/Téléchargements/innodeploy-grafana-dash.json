```yaml
__inputs:
  - name: DS_PROMETHEUS
    label: Prometheus
    type: datasource
    pluginId: prometheus

title: "InnoDeploy — Platform Overview"
uid: "innodeploy-platform"

tags:
  - innodeploy
  - kubernetes
  - argocd
  - rollout

timezone: browser
refresh: 30s

time:
  from: now-1h
  to: now

schemaVersion: 38

templating:
  list:
    - name: namespace
      type: query
      datasource:
        type: prometheus
        uid: "${DS_PROMETHEUS}"
      definition: label_values(kube_pod_info, namespace)
      label: Namespace
      current:
        text: helm-dev
        value: helm-dev

panels:

  # =========================
  # PLATFORM HEALTH
  # =========================

  - id: 1
    type: row
    title: "Platform Health"

  - id: 2
    title: "Rollout Health"
    type: stat
    datasource:
      type: prometheus
      uid: "${DS_PROMETHEUS}"

    targets:
      - expr: |
          kube_deployment_status_replicas_available{
            namespace="$namespace",
            deployment="helm-dev-innodeploy-chart"
          }

    gridPos:
      x: 0
      y: 1
      w: 6
      h: 4

    options:
      reduceOptions:
        calcs:
          - lastNotNull

      colorMode: background
      graphMode: none

    fieldConfig:
      defaults:
        thresholds:
          mode: absolute
          steps:
            - color: red
              value: 0
            - color: green
              value: 1

  - id: 3
    title: "Available Pods"
    type: stat

    datasource:
      type: prometheus
      uid: "${DS_PROMETHEUS}"

    targets:
      - expr: |
          kube_deployment_status_replicas_available{
            namespace="$namespace",
            deployment="helm-dev-innodeploy-chart"
          }

    gridPos:
      x: 6
      y: 1
      w: 6
      h: 4

    options:
      reduceOptions:
        calcs:
          - lastNotNull

  - id: 4
    title: "Pod Restarts (1h)"
    type: stat

    datasource:
      type: prometheus
      uid: "${DS_PROMETHEUS}"

    targets:
      - expr: |
          increase(
            kube_pod_container_status_restarts_total{
              namespace="$namespace",
              pod=~"helm-dev-innodeploy-chart.*"
            }[1h]
          )

    gridPos:
      x: 12
      y: 1
      w: 6
      h: 4

  - id: 5
    title: "Running Pods"
    type: stat

    datasource:
      type: prometheus
      uid: "${DS_PROMETHEUS}"

    targets:
      - expr: |
          count(
            kube_pod_status_phase{
              namespace="$namespace",
              phase="Running"
            }
          )

    gridPos:
      x: 18
      y: 1
      w: 6
      h: 4

  # =========================
  # RESOURCE MONITORING
  # =========================

  - id: 10
    type: row
    title: "Resource Monitoring"

  - id: 11
    title: "CPU Usage — Pods"
    type: timeseries

    datasource:
      type: prometheus
      uid: "${DS_PROMETHEUS}"

    targets:
      - expr: |
          sum(
            rate(
              container_cpu_usage_seconds_total{
                namespace="$namespace",
                pod=~"helm-dev-innodeploy-chart.*",
                container!="",
                image!=""
              }[2m]
            )
          ) by (pod)

        legendFormat: "{{pod}}"

    gridPos:
      x: 0
      y: 6
      w: 12
      h: 8

  - id: 12
    title: "Memory Usage — Pods"
    type: timeseries

    datasource:
      type: prometheus
      uid: "${DS_PROMETHEUS}"

    targets:
      - expr: |
          sum(
            container_memory_working_set_bytes{
              namespace="$namespace",
              pod=~"helm-dev-innodeploy-chart.*",
              container!="",
              image!=""
            }
          ) by (pod)

        legendFormat: "{{pod}}"

    gridPos:
      x: 12
      y: 6
      w: 12
      h: 8

  # =========================
  # NODE MONITORING
  # =========================

  - id: 20
    type: row
    title: "Node Monitoring"

  - id: 21
    title: "Node CPU Usage"
    type: gauge

    datasource:
      type: prometheus
      uid: "${DS_PROMETHEUS}"

    targets:
      - expr: |
          1 - avg(
            rate(node_cpu_seconds_total{mode="idle"}[2m])
          )

    gridPos:
      x: 0
      y: 15
      w: 12
      h: 8

    fieldConfig:
      defaults:
        unit: percentunit
        min: 0
        max: 1

  - id: 22
    title: "Node Memory Usage"
    type: gauge

    datasource:
      type: prometheus
      uid: "${DS_PROMETHEUS}"

    targets:
      - expr: |
          1 - (
            node_memory_MemAvailable_bytes
            /
            node_memory_MemTotal_bytes
          )

    gridPos:
      x: 12
      y: 15
      w: 12
      h: 8

    fieldConfig:
      defaults:
        unit: percentunit
        min: 0
        max: 1

  # =========================
  # ALERTS
  # =========================

  - id: 30
    type: row
    title: "Alerts"

  - id: 31
    title: "Active Alerts"
    type: alertlist

    gridPos:
      x: 0
      y: 24
      w: 24
      h: 8

    options:
      maxItems: 20
      stateFilter:
        firing: true
        pending: true
```

