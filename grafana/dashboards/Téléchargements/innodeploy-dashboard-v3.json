{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "title": "InnoDeploy \u2014 Platform Overview v3",
  "uid": "innodeploy-platform-v3",
  "tags": [
    "innodeploy",
    "kubernetes",
    "argocd",
    "rollout"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "schemaVersion": 38,
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "definition": "label_values(kube_pod_info, namespace)",
        "label": "Namespace",
        "multi": false,
        "includeAll": false,
        "current": {
          "text": "helm-dev",
          "value": "helm-dev"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Platform Health",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 2,
      "title": "Rollout Health",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "kube_deployment_status_replicas_available{\n  namespace=\"$namespace\",\n  deployment=~\"(helm-dev-|innodeploy-)innodeploy-chart\"\n}\n",
          "legendFormat": "Replicas available"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Available Pods",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "kube_deployment_status_replicas_available{\n  namespace=\"$namespace\",\n  deployment=~\"(helm-dev-|innodeploy-)innodeploy-chart\"\n}\n",
          "legendFormat": "Available"
        }
      ],
      "gridPos": {
        "x": 6,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "green",
                "value": 2
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Pod Restarts (1h)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum(\n  increase(\n    kube_pod_container_status_restarts_total{\n      namespace=\"$namespace\",\n      pod=~\"(helm-dev-innodeploy-chart|innodeploy-innodeploy-chart).*\"\n    }[1h]\n  )\n)\n",
          "legendFormat": "Restarts"
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 3
              }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Running Pods",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "count(\n  kube_pod_status_phase{\n    namespace=\"$namespace\",\n    phase=\"Running\"\n  }\n)\n",
          "legendFormat": "Running"
        }
      ],
      "gridPos": {
        "x": 18,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "green",
                "value": 2
              }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "type": "row",
      "title": "Resource Monitoring",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 11,
      "title": "CPU Usage \u2014 Pods",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum(\n  rate(\n    container_cpu_usage_seconds_total{\n      namespace=\"$namespace\",\n      pod=~\"(helm-dev-innodeploy-chart|innodeploy-innodeploy-chart).*\",\n      container!=\"\"\n    }[2m]\n  )\n) by (pod)",
          "legendFormat": "{{pod}}"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 12,
      "title": "Memory Usage \u2014 Pods",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum(\n  container_memory_working_set_bytes{\n    namespace=\"$namespace\",\n    pod=~\"(helm-dev-innodeploy-chart|innodeploy-innodeploy-chart).*\",\n    container!=\"\"\n  }\n) by (pod)",
          "legendFormat": "{{pod}}"
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 6,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 20,
      "type": "row",
      "title": "Node Monitoring",
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 21,
      "title": "Node CPU Usage",
      "type": "gauge",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "1 - avg(\n  rate(\n    node_cpu_seconds_total{mode=\"idle\"}[2m]\n  )\n)\n",
          "legendFormat": "CPU Used"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 12,
        "h": 8
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 0.6
              },
              {
                "color": "red",
                "value": 0.85
              }
            ]
          }
        }
      }
    },
    {
      "id": 22,
      "title": "Node Memory Usage",
      "type": "gauge",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "1 - (\n  node_memory_MemAvailable_bytes\n  /\n  node_memory_MemTotal_bytes\n)\n",
          "legendFormat": "Memory Used"
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 15,
        "w": 12,
        "h": 8
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 0.7
              },
              {
                "color": "red",
                "value": 0.9
              }
            ]
          }
        }
      }
    },
    {
      "id": 30,
      "type": "row",
      "title": "GitOps \u2014 ArgoCD",
      "gridPos": {
        "x": 0,
        "y": 23,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 31,
      "title": "ArgoCD Sync Status",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "argocd_app_info{\n  namespace=\"argocd\",\n  sync_status=\"Synced\"\n}\n",
          "legendFormat": "{{name}} \u2014 Synced"
        },
        {
          "expr": "argocd_app_info{\n  namespace=\"argocd\",\n  sync_status=\"OutOfSync\"\n}\n",
          "legendFormat": "{{name}} \u2014 OutOfSync"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 12,
        "h": 5
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "id": 32,
      "title": "Deployment Frequency (24h)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum(\n  increase(\n    argocd_app_sync_total{\n      namespace=\"argocd\",\n      phase=\"Succeeded\"\n    }[24h]\n  )\n)\n",
          "legendFormat": "Successful syncs"
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 24,
        "w": 6,
        "h": 5
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 33,
      "title": "ArgoCD App Health",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "argocd_app_info{\n  namespace=\"argocd\",\n  health_status=\"Healthy\"\n}\n",
          "legendFormat": "{{name}}"
        }
      ],
      "gridPos": {
        "x": 18,
        "y": 24,
        "w": 6,
        "h": 5
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "id": 40,
      "type": "row",
      "title": "Argo Rollouts",
      "gridPos": {
        "x": 0,
        "y": 29,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 41,
      "title": "Rollout Phase",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "rollout_info{\n  namespace=\"$namespace\"\n}\n",
          "legendFormat": "{{rollout}} \u2014 {{phase}}"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 30,
        "w": 8,
        "h": 5
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "id": 42,
      "title": "Stable Replicas",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "rollout_info{\n  namespace=\"$namespace\",\n  phase=\"Healthy\"\n}\n",
          "legendFormat": "Stable"
        }
      ],
      "gridPos": {
        "x": 8,
        "y": 30,
        "w": 8,
        "h": 5
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 43,
      "title": "Canary Weight",
      "type": "gauge",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "rollout_canary_current_weight{\n  namespace=\"$namespace\"\n}\n",
          "legendFormat": "Canary %"
        }
      ],
      "gridPos": {
        "x": 16,
        "y": 30,
        "w": 8,
        "h": 5
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        }
      }
    },
    {
      "id": 50,
      "type": "row",
      "title": "Alerts",
      "gridPos": {
        "x": 0,
        "y": 35,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 51,
      "title": "Active Alerts",
      "type": "alertlist",
      "gridPos": {
        "x": 0,
        "y": 36,
        "w": 24,
        "h": 8
      },
      "options": {
        "maxItems": 20,
        "sortOrder": 1,
        "groupMode": "default",
        "stateFilter": {
          "firing": true,
          "pending": true,
          "noData": false,
          "error": false,
          "inactive": false
        }
      }
    }
  ]
}